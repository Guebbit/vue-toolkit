{
    "compilerOptions": {
        "strict": true,
        "target": "ES2023",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "sourceMap": true,
        "lib": ["dom", "esnext"],
        "allowSyntheticDefaultImports": true,
        "isolatedModules": true,
        "resolveJsonModule": true,
        "rootDir": "./src",
        "outDir": "./dist",
        "declaration": true,
        "declarationMap": true,
        "declarationDir": "./dist/types"
    },
    "include": ["src"],
    "exclude": ["node_modules", "dist"]
}
